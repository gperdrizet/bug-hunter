# Secret key for JWT signing — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret-key

# LLM provider: openai | anthropic | ollama
# Use "openai" for any OpenAI-compatible endpoint (including llama.cpp)
LLM_PROVIDER=openai

# OpenAI / llama.cpp compatible
OPENAI_API_KEY=llama-cpp          # can be any non-empty string for llama.cpp
OPENAI_MODEL=your-model-name      # model name as reported by your llama.cpp server
# Leave unset to use real OpenAI; set to your llama.cpp server's /v1 URL:
OPENAI_BASE_URL=http://localhost:8080/v1

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-5

# Ollama (local)
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# OLLAMA_MODEL=codellama

# CORS — comma-separated origins allowed to call the API
# (not needed if frontend and backend are on same origin via nginx)
# CORS_ORIGINS=https://yourdomain.com

# SMTP (optional — for email features if added later)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=you@example.com
# SMTP_PASSWORD=your-smtp-password
# SMTP_FROM=noreply@example.com
